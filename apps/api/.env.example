DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pocketguide
PORT=3001

# OpenRouteService — harita "Rotayı Başlat" (https://openrouteservice.org/dev)
ORS_API_KEY=

# Foursquare Places API — Proje → Settings → Service API Keys → Generate
# (PocketGuide satırında "Generate API Key" görüyorsan henüz key yok demektir)
# Özel karakterler için mutlaka tırnak kullan:
FOURSQUARE_API_KEY="fsq3xxxxxxxx"
# Foursquare 401 alırsan geçici ingest: pnpm seed:places:osm
# FOURSQUARE_API_BASE_URL=https://places-api.foursquare.com
# FOURSQUARE_API_VERSION=2025-06-17
